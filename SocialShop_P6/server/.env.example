# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Tạo free cluster tại https://mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/socialshop

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=doi_chuoi_nay_thanh_bi_mat_cua_ban_toi_thieu_32_ky_tu
JWT_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────
# URL frontend (để redirect sau thanh toán)
CLIENT_URL=http://localhost:3000
# URL backend (để MoMo IPN gọi vào)
SERVER_URL=http://localhost:5000

# ── Cloudinary (tùy chọn — bỏ trống để dùng local upload) ─
# Tạo free account tại https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── VNPay (sandbox — đăng ký tại https://sandbox.vnpayment.vn/devreg) ─
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Mặc định sandbox — đổi khi live:
# VNPAY_URL=https://pay.vnpay.vn/vpcpay.html

# ── MoMo (sandbox — đăng ký tại https://developers.momo.vn) ─
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
